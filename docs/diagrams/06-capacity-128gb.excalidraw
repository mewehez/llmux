    { "id": "a_binds_l", "type": "text", "x": 720, "y": 256, "width": 120, "height": 16, "angle": 0, "strokeColor": "#e8590c", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "roundness": null, "seed": 60028, "version": 1, "versionNonce": 60028, "isDeleted": false, "boundElements": [], "updated": 1, "link": null, "locked": false, "fontSize": 12, "fontFamily": 2, "text": "binds the bar", "textAlign": "left", "verticalAlign": "top", "containerId": null, "originalText": "binds the bar", "lineHeight": 1.25 },

    { "id": "foot", "type": "text", "x": 60, "y": 640, "width": 1290, "height": 36, "angle": 0, "strokeColor": "#868e96", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "roundness": null, "seed": 60029, "version": 1, "versionNonce": 60029, "isDeleted": false, "boundElements": [], "updated": 1, "link": null, "locked": false, "fontSize": 12, "fontFamily": 2, "text": "Reference: scaling-theory.md (three ceilings + USL).  Qwen models stay enabled:false until the prod box.  Dev MacBook (6 cores): small models stay burstable\n(req cpu 1, threads 4) — there the core budget isn't the constraint, so the threads==request rule is intentionally relaxed for them.", "textAlign": "left", "verticalAlign": "top", "containerId": null, "originalText": "Reference: scaling-theory.md (three ceilings + USL).  Qwen models stay enabled:false until the prod box.  Dev MacBook (6 cores): small models stay burstable\n(req cpu 1, threads 4) — there the core budget isn't the constraint, so the threads==request rule is intentionally relaxed for them.", "lineHeight": 1.4 }
